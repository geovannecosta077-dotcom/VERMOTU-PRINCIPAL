# ============================================================
# Vermotu — variáveis de ambiente
# Copie este arquivo para .env e preencha com valores reais.
# NUNCA faça commit do arquivo .env.
# ============================================================

# ── Banco de dados (PostgreSQL) ──────────────────────────────
# Formato: postgresql://usuario:senha@host:porta/banco
DATABASE_URL=postgresql://postgres:password@localhost:5432/vermotu

# ── Sessão ───────────────────────────────────────────────────
# String aleatória longa para assinar sessões/JWT
SESSION_SECRET=troque-por-uma-string-aleatoria-longa

# ── Stripe ───────────────────────────────────────────────────
# Chaves disponíveis em https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs dos planos (criar em Produtos > Preços no Stripe)
# Deixe vazio para usar preços inline (Stripe gera na hora)
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_PREMIUM=price_...

# ── Object Storage S3-compatível ─────────────────────────────
# Funciona com AWS S3, Cloudflare R2, MinIO, Backblaze B2, etc.
#
# AWS S3:
#   S3_ENDPOINT=          (deixe vazio — AWS usa o endpoint padrão)
#   S3_REGION=us-east-1
#
# Cloudflare R2 (gratuito até 10 GB):
#   S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   S3_REGION=auto
#
# MinIO local (desenvolvimento):
#   S3_ENDPOINT=http://localhost:9000
#   S3_REGION=us-east-1
#
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=vermotu-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Servidor (API Express) ────────────────────────────────────
PORT=8080

# ── Frontend (Vite) ───────────────────────────────────────────
# Necessário apenas em desenvolvimento fora do Replit
VITE_PORT=5173
BASE_PATH=/

# ── URL do servidor API (OBRIGATÓRIO na Vercel) ───────────────
# Configure esta variável no painel da Vercel (Settings → Environment Variables)
# Aponte para onde o servidor Express está hospedado (ex: Railway, Render, Fly.io)
# Exemplo: https://api.vermotu.com.br ou https://vermotu-api.up.railway.app
#
# SEM esta variável na Vercel, o login e cadastro retornam 404!
#
VITE_API_URL=

# ── CORS — origens adicionais permitidas pela API ────────────
# Lista separada por vírgula de URLs que podem chamar a API.
# Útil para adicionar previews da Vercel temporariamente.
# Exemplo: https://vermotu-abc123.vercel.app,https://meu-preview.vercel.app
ALLOWED_ORIGINS=
